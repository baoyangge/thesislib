generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PaperStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String

  isAdmin   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  papers    Paper[]
  reviews   PaperReview[] @relation("Reviewer")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  papers    Paper[]
}

model Paper {
  id          String      @id @default(cuid())
  title       String
  abstract    String?
  status      PaperStatus @default(SUBMITTED)
  isActive    Boolean     @default(true)
  viewCount   Int         @default(0)

  authorId    String
  categoryId  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  file        PaperFile?
  reviews     PaperReview[]

  @@index([status])
  @@index([isActive])
  @@index([viewCount])
  @@index([categoryId])
}

model PaperFile {
  id        String @id @default(cuid())
  paperId   String @unique

  filename  String
  mimeType  String
  sizeBytes Int
  path      String

  createdAt DateTime @default(now())

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)
}

model PaperReview {
  id         String      @id @default(cuid())
  paperId    String
  reviewerId String

  decision   PaperStatus? // APPROVED / REJECTED typically
  note       String?

  createdAt  DateTime @default(now())

  paper      Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  reviewer   User  @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([reviewerId])
}
